# 复制为 .env 后使用。本目录 local 可覆盖为 .env.local
PORT=3000

# Phase 1 API access. Use a long random value in local/prod .env files.
API_TOKEN=replace-with-local-dev-token

# OpenAI-compatible LLM gateway.
# Current MVP target: Volcengine Ark / Doubao.
# Copy your ARK_API_KEY value into AI_API_KEY; do not commit real keys.
AI_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
AI_API_KEY=replace-with-ark-api-key
AI_MODEL=doubao-seed-1-8-251228

# 点醒 Prompt 运行时调参开关（仅内网/开发调参用）。默认关闭/不设置即可。
# 设为 true 后开放 PUT/DELETE /v1/insight-v2/prompt，允许 debug 客户端运行时覆盖 System Prompt。
# 生产环境保持关闭。
# INSIGHT_V2_PROMPT_OVERRIDE_ENABLED=false

# 任一对得上的 PostgreSQL 即可：本机 Homebrew、docker compose、或 Neon/Supabase 等（常需 ?sslmode=require）
DATABASE_URL="postgresql://favorme:favorme@localhost:5432/favorme?schema=public"

# Redis 占位；限流/会话等接入时使用（见 docs/decisions/002-backend-stack.md）
# REDIS_URL=redis://127.0.0.1:6379/0
