// FavorMe — Chat / agent control-plane persistence (see docs/modules/ai-chat-orchestration.md)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  /// 登录方式未定稿前可空；接 auth 时收紧
  email     String?  @unique
  deviceId  String?  @unique

  /// 个人档案（见 ADR-006）：生日/性别/星座/MBTI 全部可空；
  /// useProfileInPrompt 控制是否在 insight-v2 注入 augmentation prompt。
  birthday           DateTime? @db.Date
  gender             String?
  zodiac             String?
  mbti               String?
  useProfileInPrompt Boolean   @default(false)

  conversations     Conversation[]
  llmInvocations    LlmInvocation[]
  insightRounds     InsightRound[]
  insightV2Sessions InsightV2Session[]
}

model InsightRound {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  userId        String
  rawQuestion   String   @db.Text
  questionsJson Json
  answersJson   Json
  conclusion    String   @db.Text
  requestId     String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([requestId])
}

/// 「点醒」动态问卷会话（见 docs/tasks/004 + ADR-005）。
/// 有状态：每轮加载 transcript → 调 LLM → 校验/收题护栏 → 回写。
model InsightV2Session {
  id             String          @id @default(cuid())
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  userId         String
  status         InsightV2Status @default(questioning)
  /// 用户原始纠结描述
  dilemma        String          @db.Text
  /// 发给模型的完整消息历史 [{ role, content }]
  transcriptJson Json
  /// 已作答题目的轨迹 [{ questionId, strategy, questionText, optionA, optionB, level }]
  answersJson    Json
  /// 已用策略 key 序列（防连用）
  strategiesJson Json
  /// 已追问次数（need_info），上限 2
  clarifyCount   Int             @default(0)
  /// finished 报告字段
  awakeningQuote String?         @db.Text
  tendency       String?
  analysis       String?         @db.Text
  actionAdvice   String?         @db.Text
  requestId      String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([requestId])
}

enum InsightV2Status {
  need_info
  questioning
  finished
}

/// Prompt 运行时覆盖（debug 调参用，见 docs/tasks/004 + ADR-005）。
/// 仅在 INSIGHT_V2_PROMPT_OVERRIDE_ENABLED=true 时生效；为空/未配置时回退到代码内置默认。
model PromptOverride {
  key       String   @id
  content   String   @db.Text
  updatedAt DateTime @updatedAt
  updatedBy String?
}

model AgentProfile {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  name          String   @unique
  defaultModel  String
  systemPrompt  String?  @db.Text
  policyVersion String   @default("1")
  promptVersion String   @default("1")
  isDefault     Boolean  @default(false)

  conversations Conversation[]
}

model Conversation {
  id             String             @id @default(cuid())
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  userId         String
  agentProfileId String
  title          String?
  status         ConversationStatus @default(ACTIVE)

  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  agentProfile  AgentProfile @relation(fields: [agentProfileId], references: [id], onDelete: Restrict)
  messages      Message[]
  memory        ConversationMemory?
  llmInvocations LlmInvocation[]

  @@index([userId])
}

enum ConversationStatus {
  ACTIVE
  ARCHIVED
}

model Message {
  id              String      @id @default(cuid())
  createdAt       DateTime    @default(now())
  conversationId  String
  role            MessageRole
  content         String      @db.Text
  seq             Int
  clientMessageId String
  /// 关联到本轮 assistant 补全的审计行（可空，如仅落 user 时）
  llmInvocations  LlmInvocation[]

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([conversationId, clientMessageId])
  @@index([conversationId, seq])
}

enum MessageRole {
  user
  assistant
  system
}

model ConversationMemory {
  id             String   @id @default(cuid())
  updatedAt      DateTime @updatedAt
  conversationId String   @unique
  summary        String?  @db.Text
  facts          Json?
  version        Int      @default(1)

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model LlmInvocation {
  id                 String  @id @default(cuid())
  createdAt          DateTime @default(now())
  requestId          String  @unique
  userId             String
  conversationId     String
  /// 若本次调用对应已落库的 assistant 消息
  messageId          String?
  model              String
  promptTokens       Int?
  completionTokens   Int?
  latencyMs          Int?
  errorCode          String?
  /// 可存 hash，不存原文
  promptHash         String?

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  message      Message?     @relation(fields: [messageId], references: [id], onDelete: SetNull)
}
