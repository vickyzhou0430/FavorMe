# 复制为 .env 后使用。本目录 local 可覆盖为 .env.local
PORT=3000

# Phase 1 API access. Use a long random value in local/prod .env files.
API_TOKEN=replace-with-local-dev-token

# OpenAI-compatible LLM gateway placeholders for Plan 01-02.
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=replace-with-provider-key
AI_MODEL=gpt-4o-mini

# 任一对得上的 PostgreSQL 即可：本机 Homebrew、docker compose、或 Neon/Supabase 等（常需 ?sslmode=require）
DATABASE_URL="postgresql://favorme:favorme@localhost:5432/favorme?schema=public"

# Redis 占位；限流/会话等接入时使用（见 docs/decisions/002-backend-stack.md）
# REDIS_URL=redis://127.0.0.1:6379/0
